# Copia este archivo como .env y llena los valores

# API Key de GROQ para generación de narrativas con IA
# Obtener en: https://console.groq.com
GROQ_API_KEY=tu_api_key_de_groq_aqui

# Clave de encriptación Fernet para credenciales Odoo
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=tu_clave_fernet_aqui
